-- ============================================================
-- 03_assertion_postgres.sql
-- PostgreSQL does not support CREATE ASSERTION.
-- Equivalent enforcement via CONSTRAINT TRIGGERS (deferrable).
-- ============================================================

-- ---------- Assertion 1 equivalent ----------
-- Successful payments must not exceed "Order".total_amount

CREATE OR REPLACE FUNCTION fn_asrt_paid_not_exceed_total()
RETURNS TRIGGER AS $$
DECLARE
  v_order_id INT;
  v_paid NUMERIC(10,2);
  v_total NUMERIC(10,2);
BEGIN
  v_order_id := COALESCE(NEW.order_id, OLD.order_id);

  SELECT COALESCE(SUM(amount), 0)
  INTO v_paid
  FROM paymenttransaction
  WHERE order_id = v_order_id
    AND payment_status = 'successful';

  SELECT total_amount
  INTO v_total
  FROM "Order"
  WHERE order_id = v_order_id;

  IF v_paid > v_total THEN
    RAISE EXCEPTION
      'Assertion violated: successful payments (%.2f) exceed order % total (%.2f).',
      v_paid, v_order_id, v_total;
  END IF;

  RETURN NULL;
END;
$$ LANGUAGE plpgsql;

-- Fire when payments change OR order total changes
CREATE CONSTRAINT TRIGGER asrt_paid_not_exceed_total_on_payment
AFTER INSERT OR UPDATE OR DELETE ON paymenttransaction
DEFERRABLE INITIALLY DEFERRED
FOR EACH ROW
EXECUTE FUNCTION fn_asrt_paid_not_exceed_total();

CREATE CONSTRAINT TRIGGER asrt_paid_not_exceed_total_on_order
AFTER UPDATE OF total_amount ON "Order"
DEFERRABLE INITIALLY DEFERRED
FOR EACH ROW
EXECUTE FUNCTION fn_asrt_paid_not_exceed_total();


-- ---------- Assertion 2 equivalent ----------
-- If an order is marked delivered, there must exist delivery confirmation details.

CREATE OR REPLACE FUNCTION fn_asrt_delivered_order_has_delivery()
RETURNS TRIGGER AS $$
DECLARE
  v_order_id INT;
  v_status VARCHAR(30);
BEGIN
  v_order_id := COALESCE(NEW.order_id, OLD.order_id);

  SELECT order_status
  INTO v_status
  FROM "Order"
  WHERE order_id = v_order_id;

  IF v_status = 'delivered' THEN
    IF NOT EXISTS (
      SELECT 1
      FROM delivery d
      WHERE d.order_id = v_order_id
        AND d.delivery_status = 'delivered'
        AND d.dropoff_time IS NOT NULL
    ) THEN
      RAISE EXCEPTION
        'Assertion violated: order % is delivered but missing delivered delivery with dropoff_time.',
        v_order_id;
    END IF;
  END IF;

  RETURN NULL;
END;
$$ LANGUAGE plpgsql;

-- Fire when order status changes OR delivery changes
CREATE CONSTRAINT TRIGGER asrt_delivered_order_has_delivery_on_order
AFTER UPDATE OF order_status ON "Order"
DEFERRABLE INITIALLY DEFERRED
FOR EACH ROW
EXECUTE FUNCTION fn_asrt_delivered_order_has_delivery();

CREATE CONSTRAINT TRIGGER asrt_delivered_order_has_delivery_on_delivery
AFTER INSERT OR UPDATE OR DELETE ON delivery
DEFERRABLE INITIALLY DEFERRED
FOR EACH ROW
EXECUTE FUNCTION fn_asrt_delivered_order_has_delivery();